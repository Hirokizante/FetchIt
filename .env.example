# FetchIt Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE CONFIGURATION (MySQL via Railway)
# ===========================================
# These are automatically set by Railway when you add a MySQL plugin
MYSQLHOST=localhost
MYSQLUSER=root
MYSQLPASSWORD=your_mysql_password
MYSQLDATABASE=fetchit
MYSQLPORT=3306

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
NODE_ENV=production

# ===========================================
# SESSION CONFIGURATION
# ===========================================
# Generate a secure random string for production
SESSION_SECRET=your_secure_session_secret_here